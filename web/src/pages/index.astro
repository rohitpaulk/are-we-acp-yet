---
import "../styles/global.css";
import mockData from "../data/mock-results.json";
import AgentCard from "../components/AgentCard";
import StatusPill from "../components/StatusPill";

const formatHumanDate = (value: string) => {
  const [year, month, day] = value.split("-").map(Number);
  const date = new Date(year, month - 1, day);
  const suffix =
    day >= 11 && day <= 13
      ? "th"
      : (["th", "st", "nd", "rd"][day % 10] ?? "th");

  return `${day}${suffix} ${date.toLocaleString("en", {
    month: "long",
  })} ${year}`;
};

const agents = [...mockData.agents].sort((a, b) => {
  const pctA =
    a.checks.filter((c) => c.status === "pass").length / a.checks.length;
  const pctB =
    b.checks.filter((c) => c.status === "pass").length / b.checks.length;
  return pctB - pctA;
});
const lastUpdated = formatHumanDate(mockData.lastUpdated);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Are we ACP yet?</title>
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <div class="max-w-5xl mx-auto px-7">
      <header class="pt-24 pb-12 text-center">
        <img
          src="/logos/acp.svg"
          alt="ACP"
          class="mb-5 h-10 opacity-70 inline-block"
        />
        <h1 class="text-5xl font-bold tracking-tighter leading-none text-text">
          Are we ACP yet?
        </h1>
        <StatusPill client:load />
        <p class="mt-8 text-text-muted text-base leading-relaxed">
          <span class="text-green font-semibold">Green</span> checks pass,
          <span class="text-red font-semibold">red</span> checks fail. <br />
          Hover to see details.
        </p>
        <div class="mt-8 flex items-center justify-center gap-2">
          <a
            href="https://agentclientprotocol.com/"
            target="_blank"
            class="inline-flex items-center gap-1.5 border border-border bg-surface px-3 py-1.5 text-xs font-semibold text-text-muted no-underline transition-colors hover:border-border-hover hover:text-text"
          >
            <svg
              aria-hidden="true"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.5 9a2.5 2.5 0 0 1 4.34 1.69c0 1.67-1.68 2.18-1.84 3.31"
              ></path>
              <path d="M12 17h.01"></path>
            </svg>
            What's this?
          </a>
          <a
            href="https://github.com/rohitpaulk/acp-verifier"
            target="_blank"
            class="inline-flex items-center gap-1.5 border border-border bg-surface px-3 py-1.5 text-xs font-semibold text-text-muted no-underline transition-colors hover:border-border-hover hover:text-text"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >
            View on GitHub &rarr;
          </a>
        </div>
      </header>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {agents.map((agent) => <AgentCard client:load {...agent} />)}
      </div>

      <div
        class="flex items-center justify-between mt-8 pt-5 pb-10 border-t border-border text-xs text-text-muted"
      >
        <div class="flex items-center gap-4">
          <span
            >Last updated: <span class="text-text-dim">{lastUpdated}</span
            ></span
          >
        </div>
        <a
          href="https://github.com/rohitpaulk/acp-verifier"
          target="_blank"
          class="text-text-muted no-underline transition-colors hover:text-text"
        >
          How are these checks determined? &rarr;
        </a>
      </div>
    </div>

    <style is:global>
      .check-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(28px, 1fr));
        gap: 4px;
      }

      .cell-anchor {
        position: relative;
        width: 100%;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 0;
        background: transparent;
        appearance: none;
        padding: 0;
        font: inherit;
        cursor: default;
      }

      .cell {
        width: 100%;
        height: 100%;
        border-radius: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 0.12s ease,
          box-shadow 0.12s ease;
      }

      .cell-anchor:hover,
      .cell-anchor[data-popup-open] {
        z-index: 10;
      }

      .cell-anchor:hover .cell,
      .cell-anchor[data-popup-open] .cell {
        transform: scale(1.25);
      }

      .cell.pass {
        background: var(--color-green-bg);
        color: var(--color-green);
        border: 1.5px solid var(--color-green-border);
      }

      .cell-anchor:hover .cell.pass,
      .cell-anchor[data-popup-open] .cell.pass {
        background: var(--color-green-bg-hover);
        box-shadow: 0 0 12px rgba(45, 212, 104, 0.15);
      }

      .cell.fail {
        background: var(--color-red-bg);
        color: var(--color-red);
        border: 1.5px solid var(--color-red-border);
      }

      .cell-anchor:hover .cell.fail,
      .cell-anchor[data-popup-open] .cell.fail {
        background: var(--color-red-bg-hover);
        box-shadow: 0 0 12px rgba(240, 72, 72, 0.15);
      }

      .tooltip-popup {
        background: var(--color-tooltip-bg);
        color: var(--color-text);
        border: 1px solid var(--color-tooltip-border);
        border-radius: 0;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
        font-size: 0.85rem;
        font-weight: 500;
        text-align: left;
        padding: 14px 16px;
        z-index: 50;
        max-width: 280px;
      }

      .tooltip-icon {
        width: 20px;
        height: 20px;
        border-radius: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .tooltip-icon.pass {
        background: var(--color-green-bg);
        color: var(--color-green);
        border: 1.5px solid var(--color-green-border);
      }

      .tooltip-icon.fail {
        background: var(--color-red-bg);
        color: var(--color-red);
        border: 1.5px solid var(--color-red-border);
      }

      .status-tooltip-popup {
        max-width: none;
        padding: 8px 10px;
        font-size: 0.75rem;
        text-align: center;
        white-space: nowrap;
      }
    </style>
  </body>
</html>
